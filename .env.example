# Anthropic API Key - Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SerpAPI Key - Get from https://serpapi.com (for Google Jobs search)
SERPAPI_KEY=your_serpapi_key_here

# Optional: LinkedIn RapidAPI Key - Get from https://rapidapi.com/rockapis-rockapis-default/api/linkedin-jobs-search
RAPIDAPI_KEY=your_rapidapi_key_here

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Database
DATABASE_URL=sqlite:///./resume_matcher.db

# File Upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads
